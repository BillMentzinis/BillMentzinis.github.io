---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
---

<BaseLayout title="CV" sideBarActiveItemID="cv">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Profile</div>
  </div>

  <div class="mb-10 text-justify">
    My name is Bill and I am a graduate student at the Department of Informatics and Telecommunications
    of the National and Kapodistrian University of Athens (NKUA) and a Research Assistant at the SCAN Lab.
    My primary research interests lie in Machine Learning and Data Science, exploring their diverse applications
    in Mobile Networking, Internet of Things (IoT), Computer Vision, and Automation.
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="MSc in Computer Science"
      subtitle="Oct 2025 – Jun 2027 (expected) | National and Kapodistrian University of Athens, Dept. of Informatics & Telecommunications, Athens, Greece"
    />
    <TimeLineElement
      title="BSc in Computer Science"
      subtitle="Oct 2018 – Jun 2025 | National and Kapodistrian University of Athens, Dept. of Informatics & Telecommunications, Athens, Greece"
    />
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Experience</div>
  </div>

  <div class="time-line-container mb-10">
    <TimeLineElement
      title="ML Engineer | Research Associate"
      subtitle="Mar 2025 – Present | SCAN Lab, Dept. of Informatics & Telecommunications, NKUA, Athens, Greece"
    >
      Designing and evaluating RL/DRL-based AI systems for autonomous orchestration and resource management
      of 6G mobile networks within an EU-funded project. Developing and integrating computer vision pipelines
      for real-time drone-based applications.
    </TimeLineElement>
    <TimeLineElement
      title="BI & Analytics Intern"
      subtitle="Dec 2024 – Mar 2025 | OPAP S.A., Athens, Greece"
    >
      Built and maintained Azure Synapse Pipelines for end-to-end ETL processes and data transformation.
      Designed and delivered BI reports in Power BI, SSRS, and Tableau, communicating data-driven insights
      to both technical and non-technical stakeholders. Wrote and optimised complex SQL queries to support
      analytical and reporting workloads.
    </TimeLineElement>
    <TimeLineElement
      title="IT Support / Systems Administrator Intern"
      subtitle="Jul 2024 – Oct 2024 | STIQ, Athens, Greece"
    >
      Performed EDA and data cleaning on sales datasets to support downstream analytics. Tested statistical
      and ML forecasting models using Python (Darts library). Conducted time series analysis and forecasting
      using R (fpp3).
    </TimeLineElement>
  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Certifications</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>The Data Science Course: Complete Data Science Bootcamp — Udemy</li>
    <li>AWS Knowledge: Cloud Essentials — Amazon Web Services</li>
    <li>IEEE Certificates Program (CEU/PDH) — IEEE</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Skills</div>
  </div>

  <ul class="list-disc md:columns-3 columns-2 mx-6 mb-10">
    <li>Python</li>
    <li>C/C++</li>
    <li>SQL</li>
    <li>JavaScript</li>
    <li>PyTorch</li>
    <li>Stable-Baselines3</li>
    <li>Gym</li>
    <li>scikit-learn</li>
    <li>Darts</li>
    <li>Ultralytics / YOLO</li>
    <li>RT-DETR</li>
    <li>Azure Synapse</li>
    <li>Power BI</li>
    <li>Tableau</li>
    <li>SSRS</li>
    <li>pandas</li>
    <li>NumPy</li>
  </ul>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Languages</div>
  </div>

  <ul class="list-disc mx-6 mb-10 grid gap-2">
    <li>Greek — Native</li>
    <li>English — Full Professional Proficiency (ECPE, University of Michigan)</li>
  </ul>
</BaseLayout>
