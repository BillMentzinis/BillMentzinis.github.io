---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-xl py-1">Hey there 👋</div>
    <div class="text-5xl font-bold">I'm Bill Mentzinis</div>
    <div class="text-3xl py-3 font-bold">ML Engineer & MSc CS Student</div>
    <div class="py-2">
      <text class="text-lg">
        I am a graduate student at the Department of Informatics and Telecommunications of the
        National and Kapodistrian University of Athens (NKUA) and a Research Assistant at the SCAN Lab.
        My primary research interests lie in Machine Learning and Data Science, exploring their diverse
        applications in Mobile Networking, Internet of Things (IoT), Computer Vision, and Automation.
      </text>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://www.linkedin.com/in/vasileios-mentzinis-891a951a6/" target="_blank">Let's connect!</a>
      <a href="/cv" class="btn btn-outline ml-5">View my CV</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold mb-2">My projects</div>
  </div>

  <HorizontalCard
    title="MNIST LSH Graph Search"
    img="/post_img.webp"
    desc="Approximate nearest-neighbor search and clustering on MNIST using LSH, Hypercube projection, graph traversal (GNNS/MRNG), and a convolutional autoencoder."
    url="https://github.com/BillMentzinis/mnist-lsh-graph-search"
    badge="C++"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="CV Final Project — Early & Mid Fusion with YOLOv8"
    img="/post_img.webp"
    desc="Early and mid fusion implementation using the YOLOv8n model from Ultralytics for computer vision tasks."
    url="https://github.com/BillMentzinis/CV_Final_Project"
    badge="Computer Vision"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="LLM RAG Local"
    img="/post_img.webp"
    desc="Local Retrieval-Augmented Generation (RAG) pipeline using open-source LLMs."
    url="https://github.com/BillMentzinis/llm-rag-local"
    badge="Python"
  />
</BaseLayout>
